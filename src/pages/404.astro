---
import Layout from '../layouts/Layout.astro';
---
<Layout title="404 — Page Not Found | GeoScore">
  <section class="max-w-2xl mx-auto py-20 text-center">
    <div class="text-8xl font-extrabold gradient-text mb-4">404</div>
    <h1 class="text-2xl font-bold mb-3">Page Not Found</h1>
    <p class="text-gray-400 mb-8">The page you're looking for doesn't exist or has been moved.</p>
    <div class="flex flex-wrap gap-4 justify-center">
      <a href="/" class="px-6 py-3 rounded-xl font-semibold text-white bg-gradient-to-r from-geo-600 to-brand-600 hover:from-geo-500 hover:to-brand-500 transition">
        Back to Home
      </a>
      <a href="/tools/llms-txt-checker/" class="px-6 py-3 rounded-xl font-semibold bg-white/10 hover:bg-white/20 transition">
        llms.txt Checker
      </a>
      <a href="/blog/what-is-geo/" class="px-6 py-3 rounded-xl font-semibold bg-white/10 hover:bg-white/20 transition">
        What is GEO?
      </a>
    </div>
  </section>
</Layout>
