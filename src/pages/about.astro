---
import Layout from '../layouts/Layout.astro';
---
<Layout title="About — GeoScore Methodology & Credits">
  <section class="max-w-4xl mx-auto">
    <div class="text-center mb-12">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-medium bg-brand-500/10 text-brand-400 border border-brand-500/20 mb-4">
        Methodology &amp; Community
      </div>
      <h1 class="text-4xl font-extrabold mb-3">About GeoScore</h1>
      <p class="text-gray-400 max-w-2xl mx-auto">An open-source GEO auditing tool that synthesizes frameworks from the community's leading projects.</p>
    </div>

    <div class="card p-8 mb-8">
      <h2 class="text-xl font-bold mb-4">Scoring Methodology</h2>
      <p class="text-gray-400 mb-6">
        GeoScore evaluates websites across <strong class="text-white">12 dimensions</strong> for Generative Engine Optimization (GEO) readiness,
        producing a <strong class="text-white">0-100 score</strong>. The scoring system synthesizes frameworks from 5 leading open-source projects.
      </p>

      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead><tr class="text-left border-b border-gray-700">
            <th class="pb-3 font-semibold text-gray-300 pr-4">Dimension</th><th class="pb-3 font-semibold text-gray-300 pr-4">Weight</th><th class="pb-3 font-semibold text-gray-300 pr-4">Source</th><th class="pb-3 font-semibold text-gray-300">Checks</th>
          </tr></thead>
          <tbody class="text-gray-400">
            {[
              ['AI Crawlability (Robots.txt)', '12%', 'geo-optimization-handbook, Auriti-Labs', '6'],
              ['AI Guidance (llms.txt)', '12%', 'geo-optimization-handbook, best-aeo-skill', '5'],
              ['Structured Data (Schema)', '14%', 'handbook, evolv3ai, Auriti-Labs', '8'],
              ['Meta & Social Tags', '10%', 'geo-optimization-handbook, piiiico', '5'],
              ['Content Quality', '12%', 'handbook, Auriti-Labs, geo-optimizer (Go)', '6'],
              ['E-E-A-T Signals', '8%', 'evolv3ai, best-aeo-skill', '5'],
              ['Brand & Entity', '8%', 'geo-optimization-handbook, best-aeo-skill', '4'],
              ['Citation Readiness', '8%', 'best-aeo-skill, geo-seo-claude', '5'],
              ['Discovery Endpoints', '6%', 'geo-optimization-handbook', '3'],
              ['Agent-Friendliness', '4%', 'ax-score, agentscore', '4'],
              ['Freshness & Maintenance', '4%', 'evolv3ai', '3'],
              ['Negative Signals', '&minus; (deduction)', 'handbook, UC Berkeley EMNLP 2024', '8'],
            ].map(row => (
              <tr class="border-b border-gray-700/50 card-hover">
                <td class="py-3 pr-4 text-gray-200">{row[0]}</td><td class="py-3 pr-4 font-mono text-gray-300">{row[1]}</td><td class="py-3 pr-4 text-xs text-gray-500 max-w-xs">{row[2]}</td><td class="py-3 font-mono text-gray-300">{row[3]}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <div class="card p-8 mb-8">
      <h2 class="text-xl font-bold mb-4">Score Levels</h2>
      <div class="space-y-3">
        {[
          ['86-100', 'Excellent', 'text-geo-500', 'bg-geo-500', 'Fully GEO-optimized. Well positioned for AI citation.'],
          ['68-85', 'Good', 'text-brand-500', 'bg-brand-500', 'Minor gaps remain. Targeted fixes will improve AI visibility.'],
          ['36-67', 'Basic', 'text-warn-500', 'bg-warn-500', 'Foundation exists but significant work needed.'],
          ['0-35', 'Critical', 'text-danger-500', 'bg-danger-500', 'Major overhaul required —start with robots.txt, llms.txt, schema.'],
        ].map(row => (
          <div class="flex items-start gap-4 p-4 rounded-xl bg-white/5">
            <div class={row[2] + ' font-mono font-bold text-lg whitespace-nowrap'}>{row[0]}</div>
            <div class={'px-2.5 py-0.5 rounded text-xs font-bold text-white ' + row[3]}>{row[1]}</div>
            <div class="text-gray-400 text-sm">{row[4]}</div>
          </div>
        ))}
      </div>
    </div>

    <div class="card p-8 mb-8">
      <h2 class="text-xl font-bold mb-4">Open Source Credits</h2>
      <p class="text-gray-400 mb-6">GeoScore builds on the shoulders of these open-source projects. Our gratitude to the entire GEO/AEO community.</p>

      <div class="grid md:grid-cols-2 gap-4 text-sm">
        {[
          ['qq136692547-cmyk/geo-optimization-handbook', 'Comprehensive GEO reference handbook (MIT)', 'https://github.com/qq136692547-cmyk/geo-optimization-handbook'],
          ['Auriti-Labs/geo-optimizer-skill', '8-dimension scoring, 47 strategies', 'https://github.com/Auriti-Labs/geo-optimizer-skill'],
          ['zubair-trabzada/geo-seo-claude', 'GEO-first SEO Claude skill (9K+ stars)', 'https://github.com/zubair-trabzada/geo-seo-claude'],
          ['metawhisp/best-aeo-skill', '4-vector GEO Score, 33 evidence collectors', 'https://github.com/metawhisp/best-aeo-skill'],
          ['evolv3ai/aeo-audit', '14 ranking factor AEO scoring', 'https://github.com/evolv3ai/aeo-audit'],
          ['agentgram/ax-score', 'AX Score —Lighthouse for AI Agents', 'https://github.com/agentgram/ax-score'],
          ['antlio/agentimization', 'GEO audit CLI with radar output', 'https://github.com/antlio/agentimization'],
          ['carter-wzq/geo-audit-mcp', '31-signal MCP GEO audit server', 'https://github.com/carter-wzq/geo-audit-mcp'],
          ['isreadyai/isreadyai', 'AI visibility scoring web tool', 'https://github.com/isreadyai/isreadyai'],
          ['madeburo/GEO-AI-Woo', 'WordPress GEO plugin', 'https://github.com/madeburo/GEO-AI-Woo'],
          ['geo-team-red/geo-optimizer', 'Pluggable GEO framework in Go', 'https://github.com/geo-team-red/geo-optimizer'],
          ['cxcscmu/AutoGEO', 'ICLR 2026 automated GEO framework', 'https://github.com/cxcscmu/AutoGEO'],
          ['ai-search-guru/getcito', 'AI search optimization SaaS (open-source)', 'https://github.com/ai-search-guru/getcito-worlds-first-open-source-aio-aeo-or-geo-tool'],
          ['mykpono/ultimate-seo-geo', 'Audit鈫扨lan鈫扙xecute GEO workflow', 'https://github.com/mykpono/ultimate-seo-geo'],
          ['waqasbangash121/seo-geo-analyzer', '24-factor SEO/GEO interactive dashboard', 'https://github.com/waqasbangash121/seo-geo-analyzer'],
          ['piiiico/aeo-audit', 'Schema.org and meta tag deep analysis', 'https://github.com/piiiico/aeo-audit'],
        ].map(p => (
          <a href={p[2]} target="_blank" rel="noopener" class="card-hover rounded-xl p-4">
            <div class="font-medium text-white mb-1">{p[0]}</div>
            <div class="text-gray-500 text-xs">{p[1]}</div>
          </a>
        ))}
      </div>
    </div>

    <div class="card p-8 mb-12">
      <h2 class="text-xl font-bold mb-4">Technical Notes</h2>
      <div class="space-y-4 text-sm text-gray-400">
        <div class="flex gap-3">
          <span class="w-1.5 h-1.5 rounded-full bg-brand-500 mt-2 flex-shrink-0"></span>
          <span><strong class="text-gray-300">Data source:</strong> All analysis is performed client-side by fetching publicly accessible resources (robots.txt, llms.txt, HTML, JSON-LD). No user data is collected or stored on servers.</span>
        </div>
        <div class="flex gap-3">
          <span class="w-1.5 h-1.5 rounded-full bg-brand-500 mt-2 flex-shrink-0"></span>
          <span><strong class="text-gray-300">CORS handling:</strong> Some resources are fetched via a Cloudflare Worker proxy when direct browser access is blocked.</span>
        </div>
        <div class="flex gap-3">
          <span class="w-1.5 h-1.5 rounded-full bg-brand-500 mt-2 flex-shrink-0"></span>
          <span><strong class="text-gray-300">Privacy:</strong> Audit results are stored only in your browser's localStorage. No data is transmitted to third parties.</span>
        </div>
        <div class="flex gap-3">
          <span class="w-1.5 h-1.5 rounded-full bg-brand-500 mt-2 flex-shrink-0"></span>
          <span><strong class="text-gray-300">Limitations:</strong> JavaScript-rendered content may not be fully captured. For SPAs, consider static rendering or pre-rendering for best results.</span>
        </div>
        <div class="flex gap-3">
          <span class="w-1.5 h-1.5 rounded-full bg-brand-500 mt-2 flex-shrink-0"></span>
          <span><strong class="text-gray-300">License:</strong> MIT —free to use, modify, and distribute.</span>
        </div>
      </div>
    </div>
  </section>
</Layout>
