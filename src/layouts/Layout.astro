---
import '../styles/global.css';
export interface Props {
  title?: string;
}
const { title = 'GeoScore - GEO Audit Tool' } = Astro.props;
const path = Astro.url.pathname;
---
<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Check your website visibility to AI search engines. Free GEO audit tool." />
  <meta property="og:title" content={title} />
  <meta property="og:description" content="Check your website GEO readiness score for AI search engines like ChatGPT, Perplexity, and Gemini." />
  <meta property="og:type" content="website" />
  <meta property="og:image" content="https://deng.zh.kg/og-image.svg" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content="https://deng.zh.kg/og-image.svg" />
    <link rel="sitemap" type="application/xml" href="/sitemap.xml" />
  <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).href} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="dns-prefetch" href="https://github.com" />
  <title>{title}</title>
</head>
<body class="min-h-[100dvh]">
  <header class="border-b border-gray-700/50 sticky top-0 z-50" style="background:rgba(15,23,42,0.85);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px)">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <a href="/" class="flex items-center gap-2 text-xl font-bold hover:opacity-80 transition">
          <svg class="w-8 h-8" viewBox="0 0 32 32" fill="none">
            <circle cx="16" cy="16" r="14" stroke="currentColor" stroke-width="2" class="text-geo-500"/>
            <path d="M10 20 Q16 8 22 20" stroke="currentColor" stroke-width="2.5" fill="none" class="text-brand-500"/>
            <circle cx="14" cy="18" r="1.5" fill="currentColor" class="text-geo-500"/>
            <circle cx="18" cy="18" r="1.5" fill="currentColor" class="text-geo-500"/>
          </svg>
          <span class="gradient-text">GeoScore</span>
        </a>
        <nav class="flex items-center gap-6 text-sm font-medium">
          <a href="/" class={"transition " + (path === "/" ? "text-brand-500" : "text-gray-300 hover:text-white")}>Home</a>
          <a href="/about" class={"transition " + (path === "/about" || path.startsWith("/about/") ? "text-brand-500" : "text-gray-300 hover:text-white")}>Methodology</a>
          <a href="https://github.com/qq136692547-cmyk/geo-score" target="_blank" rel="noopener" class="text-gray-300 hover:text-white transition flex items-center gap-1.5">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
            GitHub
          </a>
        </nav>
      </div>
    </div>
  </header>

  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 min-h-[calc(100dvh-8rem)]">
    <slot />
  </main>

  <footer class="border-t border-gray-700/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-gray-400">
        <p>Open-source GEO audit tool &middot; MIT Licensed</p>
        <p class="text-xs text-gray-500">Powered by <a href="https://github.com/qq136692547-cmyk/geo-optimization-handbook" class="text-brand-500 hover:underline" target="_blank">GEO Optimization Handbook</a> &middot; <a href="/about" class="text-gray-500 hover:text-gray-300 transition">Methodology</a></p>
      </div>
    </div>
  </footer>
</body>
</html>
